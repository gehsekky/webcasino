generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model user {
  id                String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name              String              @db.VarChar(256)
  email             String?             @unique @db.VarChar(256)
  salt              String?             @db.VarChar(32)
  password_hash     String?             @db.VarChar(512)
  money             Int                 @default(0)
  /// True for synthetic "bot" users that fill empty seats. Excluded from
  /// human-facing surfaces (leaderboards, search). Has effectively infinite
  /// balance for current purposes.
  is_ai             Boolean             @default(false)
  updated_at        DateTime            @default(now()) @db.Timestamptz(6)
  created_at        DateTime            @default(now()) @db.Timestamptz(6)
  hand              hand[]
  seat              seat[]
  hand_seat         hand_seat[]
  casino_table      casino_table[]
  money_transaction money_transaction[]
  oauth_identity    oauth_identity[]
}

model oauth_identity {
  id               String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id          String   @db.Uuid
  provider         String   @db.VarChar(32)
  provider_user_id String   @db.VarChar(256)
  email            String?  @db.VarChar(256)
  linked_at        DateTime @default(now()) @db.Timestamptz(6)
  user             user     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([provider, provider_user_id])
  @@index([user_id])
}

/// A persistent room where one game type is played. Has bet limits and a
/// fixed number of seats. Long-lived: many hands play out here over time.
model casino_table {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  game_type   String   @db.VarChar(32)
  minimum_bet Int
  maximum_bet Int
  max_seats   Int      @default(1)
  created_by  String   @db.Uuid
  updated_at  DateTime @default(now()) @db.Timestamptz(6)
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  user        user     @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  seat        seat[]
  hand        hand[]
}

/// A user's persistent claim on a numbered position at a table. Survives
/// across hands. When a user "stands up," the seat row is closed (modeled
/// later as a soft-delete or end-of-life marker).
model seat {
  id           String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  table_id     String       @db.Uuid
  user_id      String       @db.Uuid
  position     Int
  updated_at   DateTime     @default(now()) @db.Timestamptz(6)
  created_at   DateTime     @default(now()) @db.Timestamptz(6)
  casino_table casino_table @relation(fields: [table_id], references: [id], onDelete: Cascade)
  user         user         @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  hand_seat    hand_seat[]

  @@unique([table_id, position])
  @@index([user_id])
}

/// One round of play at a table (was: `game`). Holds the engine state in
/// `data` plus event-sourced history (planned in task #9).
model hand {
  id           String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  table_id     String       @db.Uuid
  created_by   String       @db.Uuid
  data         Json         @db.Json
  updated_at   DateTime     @default(now()) @db.Timestamptz(6)
  created_at   DateTime     @default(now()) @db.Timestamptz(6)
  casino_table casino_table @relation(fields: [table_id], references: [id], onDelete: Cascade)
  user         user         @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  hand_seat    hand_seat[]
  hand_event   hand_event[]

  @@index([table_id])
}

/// Append-only event log per hand. Source of truth for audit, replay,
/// spectator subscriptions, and the real-time push transport. The latest
/// state snapshot lives in `hand.data` (denormalized for fast reads);
/// the events table is what could rebuild it.
model hand_event {
  hand_id    String   @db.Uuid
  sequence   Int
  actor_id   String?  @db.Uuid
  action     String   @db.VarChar(64)
  payload    Json     @db.Json
  created_at DateTime @default(now()) @db.Timestamptz(6)
  hand       hand     @relation(fields: [hand_id], references: [id], onDelete: Cascade)

  @@id([hand_id, sequence])
  @@index([hand_id])
}

model money_transaction {
  id              String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id         String     @db.Uuid
  hand_seat_id    String?    @db.Uuid
  type            String     @db.VarChar(32)
  amount          Int
  note            String?    @db.VarChar(512)
  idempotency_key String?    @unique @db.VarChar(128)
  updated_at      DateTime   @default(now()) @db.Timestamptz(6)
  created_at      DateTime   @default(now()) @db.Timestamptz(6)
  hand_seat       hand_seat? @relation(fields: [hand_seat_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user            user       @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// A user's participation in one specific hand (was: `game_player`).
/// `user_id` is denormalized from `seat.user_id` at creation time so the
/// historical seat occupant survives later seat reassignment.
model hand_seat {
  id                String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  hand_id           String              @db.Uuid
  seat_id           String              @db.Uuid
  user_id           String              @db.Uuid
  data              Json                @db.Json
  updated_at        DateTime            @default(now()) @db.Timestamptz(6)
  created_at        DateTime            @default(now()) @db.Timestamptz(6)
  hand              hand                @relation(fields: [hand_id], references: [id], onDelete: Cascade)
  seat              seat                @relation(fields: [seat_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user              user                @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  money_transaction money_transaction[]

  @@unique([hand_id, seat_id])
  @@index([user_id])
}
