# Copy to .env and fill in real values. .env is gitignored.

# --- Database ---
# Inside docker compose: postgresql://postgres:postgres@db:5432/db_webcasino?schema=public
# Outside docker (host -> docker postgres on 5433):
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/db_webcasino?schema=public"

# --- Session ---
# Used to sign session cookies. Generate one with: openssl rand -hex 32
SESSION_SECRET="replace-me-with-a-long-random-string"

# --- App URL ---
# Used to build OAuth callback URLs. No trailing slash.
APP_URL="http://localhost:3000"

# --- Google OAuth ---
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must be: ${APP_URL}/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
