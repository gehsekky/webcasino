{
  "name": "web-casino",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "license": "MIT",
  "author": "Andy Chung <chung.andy@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/gehsekky/webcasino.git"
  },
  "scripts": {
    "build": "remix vite:build",
    "dev": "remix vite:dev",
    "docker": "docker compose up --build --force-recreate --no-deps",
    "docker-clean": "docker compose down && docker compose rm -fv && docker volume rm web-casino_db",
    "lint": "eslint --ignore-path .gitignore --cache --cache-location ./node_modules/.cache/eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "postinstall": "prisma generate",
    "prisma-generate": "npx prisma generate",
    "start": "remix-serve ./build/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:ui": "playwright test --ui",
    "e2e:install": "playwright install chromium",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@prisma/client": "^5.13.0",
    "@remix-run/node": "^2.9.1",
    "@remix-run/react": "^2.9.1",
    "@remix-run/serve": "^2.9.1",
    "autoprefixer": "^10.4.19",
    "crypto-js": "^4.2.0",
    "isbot": "^5.1.40",
    "pg": "^8.11.5",
    "postcss": "^8.4.38",
    "prisma": "^5.13.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "remix-auth": "^3.7.0",
    "remix-auth-google": "^2.0.0",
    "remix-utils": "^7.7.0",
    "tailwindcss": "^3.4.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@remix-run/dev": "^2.9.1",
    "@types/react": "^18.2.20",
    "@types/react-dom": "^18.2.7",
    "@typescript-eslint/eslint-plugin": "^6.7.4",
    "@typescript-eslint/parser": "^6.7.4",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^8.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.28.1",
    "eslint-plugin-jsx-a11y": "^6.7.1",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-tailwindcss": "^3.15.1",
    "fast-check": "^4.8.0",
    "prettier": "^3.8.3",
    "typescript": "^5.1.6",
    "vite": "^5.1.0",
    "vite-tsconfig-paths": "^4.2.1",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
